<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="@dimen/space_m">

    <TextView
        android:id="@+id/tvCollectorName"
        style="@style/TextAppearance.Vinilos.Title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="@color/vin_on_surface"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="Manolo Bellon" />

    <TextView
        android:id="@+id/tvCollectorTelephone"
        style="@style/TextAppearance.Vinilos.Body"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_xs"
        android:textColor="@color/vin_on_surface_muted"
        app:layout_constraintStart_toStartOf="@id/tvCollectorName"
        app:layout_constraintEnd_toEndOf="@id/tvCollectorName"
        app:layout_constraintTop_toBottomOf="@id/tvCollectorName"
        tools:text="3502457896" />

    <TextView
        android:id="@+id/tvCollectorEmail"
        style="@style/TextAppearance.Vinilos.Body"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_xs"
        android:textColor="@color/vin_on_surface_muted"
        app:layout_constraintStart_toStartOf="@id/tvCollectorName"
        app:layout_constraintEnd_toEndOf="@id/tvCollectorName"
        app:layout_constraintTop_toBottomOf="@id/tvCollectorTelephone"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:text="manollo@caracol.com.co" />

</androidx.constraintlayout.widget.ConstraintLayout>

