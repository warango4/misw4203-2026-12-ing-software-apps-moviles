<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="260dp"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/vin_surface_high"
    app:cardCornerRadius="@dimen/radius_l"
    app:cardElevation="0dp"
    app:strokeColor="@color/vin_outline"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="@dimen/space_s"
        android:paddingBottom="@dimen/space_s">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_m"
            android:layout_marginTop="@dimen/space_xs"
            android:layout_marginBottom="@dimen/space_s"
            android:letterSpacing="0.08"
            android:text="@string/role_switch_header"
            android:textAllCaps="true"
            android:textColor="@color/vin_on_surface_muted"
            android:textSize="11sp" />

        <!-- Visitante -->
        <LinearLayout
            android:id="@+id/optionGuest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/space_m">

            <FrameLayout
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_role_icon_gray">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_person_role" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_m"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvGuestName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/role_guest"
                    android:textColor="@color/vin_on_surface"
                    android:textSize="15sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/role_guest_subtitle"
                    android:textColor="@color/vin_on_surface_muted"
                    android:textSize="12sp" />
            </LinearLayout>

            <View
                android:id="@+id/dotGuest"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_selection_dot"
                android:visibility="invisible" />
        </LinearLayout>

        <!-- Coleccionista -->
        <LinearLayout
            android:id="@+id/optionCollector"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/space_m">

            <FrameLayout
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_role_icon_purple">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_shield" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_m"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvCollectorName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/role_collector"
                    android:textColor="@color/vin_primary"
                    android:textSize="15sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/role_collector_subtitle"
                    android:textColor="@color/vin_on_surface_muted"
                    android:textSize="12sp" />
            </LinearLayout>

            <View
                android:id="@+id/dotCollector"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_selection_dot"
                android:visibility="invisible" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
